/* ============ ROMANIZATION ENGINE ============ */
const INIT = ["g","kk","n","d","tt","r","m","b","pp","s","ss","","j","jj","ch","k","t","p","h"];
const MED = ["a","ae","ya","yae","eo","e","yeo","ye","o","wa","wae","oe","yo","u","wo","we","wi","yu","eu","ui","i"];
const FIN = ["","k","k","k","n","n","n","t","l","k","m","l","l","l","p","l","m","p","p","t","t","ng","t","t","k","t","p","t"];
function romanizeSyllable(ch){
  const code = ch.charCodeAt(0) - 0xAC00;
  if(code < 0 || code > 11171) return ch;
  const ini = Math.floor(code / (21*28));
  const med = Math.floor((code % (21*28)) / 28);
  const fin = code % 28;
  return INIT[ini] + MED[med] + FIN[fin];
}
function romanizeName(str){
  return str.split("").map(romanizeSyllable).join("-");
}
function toTitle(s){ return s.charAt(0).toUpperCase()+s.slice(1); }
function romanizeDisplay(str){
  const parts = str.split("").map(romanizeSyllable);
  return toTitle(parts.join(""));
}

