  }
};
const genCache = {};
function buildCombos(kind){
  const {first, second} = banks[kind];
  const combos = [];
  first.forEach(f=>{
    second.forEach(s=>{
      if(f!==s) combos.push(f+s);
    });
  });
  return combos;
}
function renderGen(kind){
  if(!genCache[kind]) genCache[kind] = buildCombos(kind);
  const filterId = {male:"genMaleFilter",female:"genFemaleFilter",neutral:"genNeutralFilter"}[kind];
  const gridId = {male:"genMaleGrid",female:"genFemaleGrid",neutral:"genNeutralGrid"}[kind];
  const countId = {male:"genMaleCount",female:"genFemaleCount",neutral:"genNeutralCount"}[kind];
  const filterVal = document.getElementById(filterId).value.trim();
  let list = genCache[kind];
  if(filterVal) list = list.filter(n=>n.includes(filterVal));
  const shuffled = [...list];
  document.getElementById(countId).textContent = `${list.length.toLocaleString()}개 조합`;
  document.getElementById(gridId).innerHTML = shuffled.map(n=>`
    <div class="gen-item"><div class="kn">${n}</div><div class="en">${romanizeDisplay(n)}</div></div>`).join("");
}
["male","female","neutral"].forEach(kind=>{
  renderGen(kind);
  const filterId = {male:"genMaleFilter",female:"genFemaleFilter",neutral:"genNeutralFilter"}[kind];
  document.getElementById(filterId).addEventListener("input", ()=>renderGen(kind));
});

